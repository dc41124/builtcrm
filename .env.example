DATABASE_URL=postgres://user:pass@host/db
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

TRIGGER_SECRET_KEY=

# ---------------------------------------------------------------------------
# Integrations — Step 25 (OAuth 2.0 scaffolding)
# ---------------------------------------------------------------------------
# INTEGRATION_ENCRYPTION_KEY — 32 random bytes, base64-encoded. Used by
#   src/lib/integrations/crypto.ts to AES-256-GCM encrypt every OAuth access
#   and refresh token before it's written to integration_connections.
# Generate with:   openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=

# INTEGRATION_STATE_SECRET — 32 random bytes, base64-encoded. HMAC-SHA256
#   signing key for the OAuth `state` parameter. Prevents CSRF on the callback.
# Generate with:   openssl rand -base64 32
INTEGRATION_STATE_SECRET=

# Per-provider OAuth app credentials. Register the app in each provider's
# developer portal; redirect URI must be `<app-base>/api/oauth/<provider>/callback`.
# QuickBooks Online — register a free "sandbox" app at developer.intuit.com.
# Set the redirect URI in the Intuit app config to
# `<app-base>/api/oauth/quickbooks_online/callback`. Production OAuth is
# gated on Intuit app review; see README § Third-party integrations.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# Xero — register a free app at developer.xero.com. Set the redirect URI to
# `<app-base>/api/oauth/xero/callback`. Production OAuth is gated on Xero
# app review; see README § Third-party integrations.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Sage Business Cloud Accounting — register at developer.sage.com. Set the
# redirect URI to `<app-base>/api/oauth/sage_business_cloud/callback`.
# Production OAuth is gated on Sage's partner program; see README
# § Third-party integrations.
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe Connect uses the existing STRIPE_SECRET_KEY (not a per-provider OAuth
# app). See src/app/api/contractor/stripe/connect/onboard/route.ts.

# ---------------------------------------------------------------------------
# Inbound webhook signing secrets — Step 26
# ---------------------------------------------------------------------------
# Each provider's developer dashboard shows the secret/verifier token used to
# sign outbound webhook callbacks. The secrets below are NOT the same as the
# OAuth client secrets above; they're specific to the webhook subscription.

# QuickBooks Online: "Verifier Token" from the webhook config in the Intuit
# developer portal. Signature header: `intuit-signature`,
# value = base64(HMAC-SHA256(rawBody, verifierToken)).
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=

# Xero: "Webhook key" shown when creating a webhook subscription in the Xero
# developer portal. Signature header: `x-xero-signature`,
# value = base64(HMAC-SHA256(rawBody, webhookKey)).
XERO_WEBHOOK_KEY=

# Sage Business Cloud: generic HMAC shared secret. Signature header:
# `x-sage-signature` (provider docs sparse — revisit when live endpoint ships).
SAGE_WEBHOOK_SECRET=

# Stripe's webhook secret is STRIPE_WEBHOOK_SECRET (defined elsewhere in the
# Stripe billing setup). Stripe's inbound webhook keeps its own static route
# at /api/webhooks/stripe — it does NOT flow through /api/webhooks/[provider].
