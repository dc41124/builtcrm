# Copy to .env.test and fill in the Neon test branch URL.
# The test suite expects this to be an isolated branch — NEVER point it at dev
# or prod, as globalSetup will purge rows it owns.
#
# Tests use a single admin-level URL: fixture setup TRUNCATEs and creates
# rows across many tables, which needs DDL. No app-role split for tests —
# the security benefit is nil on an isolated test branch.
TEST_DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Fake values are fine; tests mock @/lib/storage and never hit R2.
R2_ACCOUNT_ID=test
R2_ACCESS_KEY_ID=test
R2_SECRET_ACCESS_KEY=test
R2_BUCKET_NAME=test

# Unused at test time but env.ts validates them at import.
BETTER_AUTH_SECRET=test-secret-that-is-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
TRIGGER_SECRET_KEY=test
UPSTASH_REDIS_REST_URL=http://localhost
UPSTASH_REDIS_REST_TOKEN=test
NEXT_PUBLIC_APP_URL=http://localhost:3000
